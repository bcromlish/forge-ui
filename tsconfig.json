{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@forge-ui/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/__tests__/**",
    "src/editor/**",
    "src/providers/**",
    "src/foundations/**",
    "src/compositions/audit-log/**",
    "src/compositions/showcase/**",
    "src/compositions/analytics/DateRangeSelector.tsx",
    "src/compositions/analytics/PipelineFunnel.tsx",
    "src/compositions/analytics/SourceBreakdown.tsx",
    "src/compositions/analytics/TimeToFill.tsx",
    "src/compositions/calendar/AgendaNotesSection.tsx",
    "src/compositions/calendar/AttendeesSection.tsx",
    "src/compositions/calendar/AvailabilityEventDetail.tsx",
    "src/compositions/calendar/BufferBlock.tsx",
    "src/compositions/calendar/CalendarDayView.tsx",
    "src/compositions/calendar/CalendarEventBlock.tsx",
    "src/compositions/calendar/CalendarEventDetail.tsx",
    "src/compositions/calendar/CalendarEventFormSheet.tsx",
    "src/compositions/calendar/CalendarMonthView.tsx",
    "src/compositions/calendar/CalendarPageContent.tsx",
    "src/compositions/calendar/CalendarQuickCreate.tsx",
    "src/compositions/calendar/CalendarToolbar.tsx",
    "src/compositions/calendar/CalendarWeekView.tsx",
    "src/compositions/calendar/DayColumnWithDrag.tsx",
    "src/compositions/calendar/DayRowWithDrag.tsx",
    "src/compositions/calendar/InterviewEventDetail.tsx",
    "src/compositions/calendar/MeetingEventDetail.tsx",
    "src/compositions/calendar/QuickCreateInterviewForm.tsx",
    "src/compositions/calendar/QuickCreateMeetingForm.tsx",
    "src/compositions/calendar/RsvpWell.tsx",
    "src/compositions/calendar/TeamMemberFilter.tsx",
    "src/compositions/calendar/TodayEvents.tsx",
    "src/compositions/settings/AuthMethodsList.tsx",
    "src/compositions/settings/DynamicFieldRenderer.tsx",
    "src/compositions/settings/EditMemberDialog.tsx",
    "src/compositions/settings/FieldDefinitionManager.tsx",
    "src/compositions/settings/FieldDefinitionRow.tsx",
    "src/compositions/settings/InviteMemberDialog.tsx",
    "src/compositions/settings/MembersTableSkeleton.tsx",
    "src/compositions/settings/MembersTable.tsx",
