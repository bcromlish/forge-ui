    "src/compositions/settings/WorkspaceAccessEditor.tsx",
    "src/compositions/page-builder/AddBlockMenu.tsx",
    "src/compositions/page-builder/BlockConfigPanel.tsx",
    "src/compositions/page-builder/BlockContextMenu.tsx",
    "src/compositions/page-builder/BlockRenderer.tsx",
